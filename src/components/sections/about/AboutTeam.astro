---
import aboutData from "../../../data/about.json";
import BrushDivider from "../../ui/BrushDivider.astro";

const { team } = aboutData;
---

<div>
  <section class="bg-[#f9f1f1] pt-0 pb-16 md:pb-20">
  <div class="relative z-10 -mt-12 md:-mt-16 rotate-180">
    <BrushDivider class="text-white" flip />
  </div>

  <div class="container-main text-center pt-14 md:pt-20">
    <span
      class="inline-block text-primary font-bold text-xs md:text-sm uppercase tracking-[0.15em] mb-3"
    >
      {team.subtitle}
    </span>
    <h2
      class="text-3xl sm:text-4xl md:text-5xl font-extrabold text-heading mb-12 md:mb-16"
    >
      {team.title}
    </h2>

    <div
      class="grid grid-cols-1 sm:grid-cols-3 gap-10 md:gap-8 max-w-8xl mx-auto"
    >
      {
        team.members.map((member) => (
          <div class="text-center">
            <div
              class="w-64 h-64 md:w-80 md:h-80 rounded-full overflow-hidden mx-auto mb-5"
              style={`background-color: ${member.bg}`}
            >
              <img
                src={member.avatar}
                alt={member.name}
                class="w-full h-full !h-full object-cover"
              />
            </div>
            <h4 class="text-base md:text-lg font-bold text-heading">
              {member.name}
            </h4>
          </div>
        ))
      }
    </div>
  </div>

  
</section>
<BrushDivider />
</div>
