---
import type { Product } from '../../types';
import SectionHeading from '../ui/SectionHeading.astro';
import ProductCard from '../cards/ProductCard.astro';
import Button from '../ui/Button.astro';

export interface Props {
  title: string;
  subtitle?: string;
  products: Product[];
  showViewAll?: boolean;
}

const { title, subtitle, products, showViewAll = false } = Astro.props;
---

<section class="py-16 md:py-20">
  <div class="container-main">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
      <SectionHeading title={title} subtitle={subtitle} align="left" class="mb-0" />
      {showViewAll && (
        <Button href="/shop" variant="outline" size="sm" class="self-start sm:self-auto">
          View All Products
        </Button>
      )}
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {products.map((product) => (
        <ProductCard product={product} />
      ))}
    </div>
  </div>
</section>
