---
import type { Icon } from '@lucide/astro';

export interface Props {
  label: string;
  value: string;
  change?: string;
  changeType?: 'up' | 'down' | 'neutral';
  icon: Icon;
  iconBg?: string;
}

const {
  label,
  value,
  change,
  changeType = 'neutral',
  icon: IconComponent,
  iconBg = 'bg-primary/10 text-primary',
} = Astro.props;

const changeColors = {
  up: 'text-success',
  down: 'text-sale',
  neutral: 'text-muted',
};
---

<div class="rounded-2xl border border-border bg-white p-5 shadow-sm transition-shadow hover:shadow-card">
  <div class="flex items-start justify-between gap-4">
    <div class="min-w-0 flex-1">
      <p class="text-sm text-muted">{label}</p>
      <p class="mt-1 text-2xl font-bold text-heading sm:text-3xl">{value}</p>
      {
        change && (
          <p class:list={['mt-2 text-xs font-medium', changeColors[changeType]]}>
            {change}
          </p>
        )
      }
    </div>
    <span class:list={['flex h-12 w-12 shrink-0 items-center justify-center rounded-xl', iconBg]}>
      <IconComponent size={22} />
    </span>
  </div>
</div>
