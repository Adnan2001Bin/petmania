---
import type { Product } from '../../types';
import Badge from '../ui/Badge.astro';
import { Star, Pencil, Trash2, Eye } from '@lucide/astro';

export interface Props {
  products: Product[];
}

const { products } = Astro.props;

const badgeLabels: Record<string, string> = {
  sale: 'Sale',
  new: 'New',
  hot: 'Hot',
  'sold-out': 'Sold Out',
};

function formatPrice(price: number) {
  return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(price);
}
---

<!-- Desktop table -->
<div class="hidden overflow-hidden rounded-2xl border border-border bg-white shadow-sm lg:block">
  <div class="overflow-x-auto">
    <table class="w-full text-left text-sm">
      <thead>
        <tr class="border-b border-border bg-light/80">
          <th class="px-5 py-4 font-semibold text-heading">Product</th>
          <th class="px-5 py-4 font-semibold text-heading">SKU</th>
          <th class="px-5 py-4 font-semibold text-heading">Category</th>
          <th class="px-5 py-4 font-semibold text-heading">Price</th>
          <th class="px-5 py-4 font-semibold text-heading">Rating</th>
          <th class="px-5 py-4 font-semibold text-heading">Stock</th>
          <th class="px-5 py-4 font-semibold text-heading">Badge</th>
          <th class="px-5 py-4 font-semibold text-heading">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border">
        {
          products.map((product) => (
            <tr class="transition-colors hover:bg-light/50">
              <td class="px-5 py-4">
                <div class="flex items-center gap-3">
                  <img
                    src={product.image}
                    alt={product.name}
                    class="h-12 w-12 rounded-xl object-cover"
                    loading="lazy"
                  />
                  <div class="min-w-0">
                    <p class="truncate font-medium text-heading">{product.name}</p>
                    <p class="truncate text-xs text-muted">{product.slug}</p>
                  </div>
                </div>
              </td>
              <td class="px-5 py-4 font-mono text-xs text-body">{product.sku}</td>
              <td class="px-5 py-4">
                <span class="rounded-lg bg-accent/10 px-2.5 py-1 text-xs font-medium text-accent">
                  {product.category}
                </span>
              </td>
              <td class="px-5 py-4">
                <div>
                  <p class="font-semibold text-heading">{formatPrice(product.price)}</p>
                  {product.oldPrice && (
                    <p class="text-xs text-muted line-through">{formatPrice(product.oldPrice)}</p>
                  )}
                </div>
              </td>
              <td class="px-5 py-4">
                <div class="flex items-center gap-1">
                  <Star size={14} class="fill-star text-star" />
                  <span class="font-medium text-heading">{product.rating}</span>
                  <span class="text-xs text-muted">({product.reviewCount})</span>
                </div>
              </td>
              <td class="px-5 py-4">
                <span
                  class:list={[
                    'inline-flex items-center gap-1.5 rounded-lg px-2.5 py-1 text-xs font-medium',
                    product.inStock ? 'bg-success/10 text-success' : 'bg-sale/10 text-sale',
                  ]}
                >
                  <span
                    class:list={[
                      'h-1.5 w-1.5 rounded-full',
                      product.inStock ? 'bg-success' : 'bg-sale',
                    ]}
                  />
                  {product.inStock ? 'In Stock' : 'Out of Stock'}
                </span>
              </td>
              <td class="px-5 py-4">
                {product.badge ? (
                  <Badge text={badgeLabels[product.badge]} type={product.badge} />
                ) : (
                  <span class="text-xs text-muted">—</span>
                )}
              </td>
              <td class="px-5 py-4">
                <div class="flex items-center gap-1">
                  <a
                    href={`/product/${product.slug}`}
                    target="_blank"
                    class="flex h-8 w-8 items-center justify-center rounded-lg text-muted transition-colors hover:bg-light hover:text-primary"
                    aria-label={`View ${product.name}`}
                  >
                    <Eye size={16} />
                  </a>
                  <button
                    type="button"
                    class="flex h-8 w-8 items-center justify-center rounded-lg text-muted transition-colors hover:bg-light hover:text-accent"
                    aria-label={`Edit ${product.name}`}
                  >
                    <Pencil size={16} />
                  </button>
                  <button
                    type="button"
                    class="flex h-8 w-8 items-center justify-center rounded-lg text-muted transition-colors hover:bg-light hover:text-sale"
                    aria-label={`Delete ${product.name}`}
                  >
                    <Trash2 size={16} />
                  </button>
                </div>
              </td>
            </tr>
          ))
        }
      </tbody>
    </table>
  </div>
</div>

<!-- Mobile cards -->
<div class="space-y-4 lg:hidden">
  {
    products.map((product) => (
      <article class="rounded-2xl border border-border bg-white p-4 shadow-sm">
        <div class="flex gap-4">
          <img
            src={product.image}
            alt={product.name}
            class="h-20 w-20 shrink-0 rounded-xl object-cover"
            loading="lazy"
          />
          <div class="min-w-0 flex-1">
            <div class="flex items-start justify-between gap-2">
              <div>
                <h3 class="font-semibold text-heading">{product.name}</h3>
                <p class="text-xs text-muted">{product.sku}</p>
              </div>
              {product.badge && <Badge text={badgeLabels[product.badge]} type={product.badge} />}
            </div>
            <div class="mt-2 flex flex-wrap items-center gap-2">
              <span class="rounded-lg bg-accent/10 px-2 py-0.5 text-xs font-medium text-accent">
                {product.category}
              </span>
              <span
                class:list={[
                  'rounded-lg px-2 py-0.5 text-xs font-medium',
                  product.inStock ? 'bg-success/10 text-success' : 'bg-sale/10 text-sale',
                ]}
              >
                {product.inStock ? 'In Stock' : 'Out of Stock'}
              </span>
            </div>
            <div class="mt-3 flex items-center justify-between">
              <div>
                <p class="font-bold text-heading">{formatPrice(product.price)}</p>
                {product.oldPrice && (
                  <p class="text-xs text-muted line-through">{formatPrice(product.oldPrice)}</p>
                )}
              </div>
              <div class="flex items-center gap-1 text-sm">
                <Star size={14} class="fill-star text-star" />
                <span class="font-medium">{product.rating}</span>
              </div>
            </div>
            <div class="mt-3 flex flex-wrap gap-1">
              {product.tags.map((tag) => (
                <span class="rounded-md bg-light px-2 py-0.5 text-[10px] text-muted">#{tag}</span>
              ))}
            </div>
          </div>
        </div>
      </article>
    ))
  }
</div>
