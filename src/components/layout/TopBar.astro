---
import { MapPin, Truck, Percent, Phone } from '@lucide/astro';
---

<div class="bg-dark text-white text-xs py-2.5">
  <div class="container-main flex flex-wrap items-center justify-between gap-2">
    <div class="hidden md:flex items-center gap-6">
      <a href="/contact" class="flex items-center gap-1.5 hover:text-primary transition-colors">
        <MapPin size={14} />
        <span>Find a Store</span>
      </a>
      <a href="#" class="flex items-center gap-1.5 hover:text-primary transition-colors">
        <Truck size={14} />
        <span>Order Tracking</span>
      </a>
      <span class="flex items-center gap-1.5 text-primary">
        <Percent size={14} />
        <span>15% Off $50+</span>
      </span>
    </div>

    <div class="flex items-center gap-4 ml-auto">
      <a href="tel:+18001234567" class="hidden sm:flex items-center gap-1.5 hover:text-primary transition-colors">
        <Phone size={14} />
        <span>+1 800 123 4567</span>
      </a>
      <div class="h-4 w-px bg-white/20 hidden sm:block"></div>
      <select class="bg-transparent text-white text-xs outline-none cursor-pointer">
        <option value="usd" class="text-heading">USD $</option>
        <option value="eur" class="text-heading">EUR €</option>
      </select>
      <select class="bg-transparent text-white text-xs outline-none cursor-pointer">
        <option value="en" class="text-heading">English</option>
        <option value="es" class="text-heading">Español</option>
      </select>
    </div>
  </div>
</div>
