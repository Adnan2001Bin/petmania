---
import { MapPin, Truck } from '@lucide/astro';
---

<div class="bg-accent text-white text-xs py-2">
  <div class="container-main flex items-center justify-between gap-4">
    <div class="hidden md:flex items-center gap-6">
      <a href="/contact" class="flex items-center gap-1.5 hover:text-white/80 transition-colors">
        <MapPin size={14} />
        <span>Find a Store</span>
      </a>
      <a href="#" class="flex items-center gap-1.5 hover:text-white/80 transition-colors">
        <Truck size={14} />
        <span>Order Tracking</span>
      </a>
    </div>

    <div class="flex items-center gap-2 text-center mx-auto md:mx-0">
      <span class="inline-block bg-primary text-white text-[11px] font-bold px-3 py-1 rounded-full">
        15% Off
      </span>
      <span class="text-white text-xs">
        $50+ when you buy online & pick up in-store
      </span>
    </div>

    <div class="hidden md:flex items-center gap-3">
      <select class="bg-transparent text-white text-xs outline-none cursor-pointer hover:text-white/80 transition-colors">
        <option value="usd" class="text-heading">USD</option>
        <option value="eur" class="text-heading">EUR</option>
      </select>
      <select class="bg-transparent text-white text-xs outline-none cursor-pointer hover:text-white/80 transition-colors">
        <option value="en" class="text-heading">English</option>
        <option value="es" class="text-heading">Español</option>
      </select>
    </div>
  </div>
</div>
