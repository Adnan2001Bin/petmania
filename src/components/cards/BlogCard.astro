---
import { Calendar, User, ChevronRight } from '@lucide/astro';
import type { BlogPost } from '../../types';

export interface Props {
  post: BlogPost;
}

const { post } = Astro.props;
const formattedDate = new Date(post.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const tagColors: Record<string, string> = {
  'Lifestyles': 'bg-primary',
  'Educational': 'bg-accent',
  'New': 'bg-emerald-500',
};
---

<article class="group bg-white rounded-lg overflow-hidden">
  <a href={`/blog/${post.slug}`} class="relative block aspect-[4/3] overflow-hidden">
    <img
      src={post.image}
      alt={post.title}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
      loading="lazy"
    />
    {post.tags && post.tags.length > 0 && (
      <div class="absolute top-4 left-4 flex flex-wrap gap-2">
        {post.tags.map((tag) => (
          <span class={`inline-block ${tagColors[tag] || 'bg-primary'} text-white text-xs font-semibold px-3 py-1 rounded`}>
            {tag}
          </span>
        ))}
      </div>
    )}
  </a>
  <div class="p-5">
    <div class="flex items-center gap-4 text-xs text-muted mb-3">
      <span class="flex items-center gap-1">
        <User size={14} />
        By <span class="font-semibold text-heading">{post.author}</span>
      </span>
      <span class="flex items-center gap-1">
        <Calendar size={14} />
        {formattedDate}
      </span>
    </div>
    <h3 class="text-lg font-bold text-heading mb-2 group-hover:text-primary transition-colors leading-snug">
      <a href={`/blog/${post.slug}`}>{post.title}</a>
    </h3>
    <p class="text-sm text-body line-clamp-2 mb-4">{post.excerpt}</p>
    <a
      href={`/blog/${post.slug}`}
      class="inline-flex items-center gap-2 px-6 py-2.5 bg-accent text-white text-sm font-semibold rounded-full hover:bg-primary transition-colors"
    >
      Read More
      <ChevronRight size={16} />
    </a>
  </div>
</article>
