---
import type { Banner } from '../../types';
import Button from '../ui/Button.astro';

export interface Props {
  banner: Banner;
  class?: string;
}

const { banner, class: className = '' } = Astro.props;
---

<a
  href={banner.link}
  class={`group relative block overflow-hidden rounded-xl ${className}`}
>
  <img
    src={banner.image}
    alt={banner.title}
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/20 to-transparent"></div>
  <div class="relative h-full flex flex-col justify-center p-6 md:p-8">
    {banner.subtitle && (
      <span class="inline-block text-primary text-sm font-semibold uppercase tracking-wider mb-2">
        {banner.subtitle}
      </span>
    )}
    <h3 class="text-2xl md:text-3xl font-bold text-white mb-2">{banner.title}</h3>
    {banner.description && (
      <p class="text-white/80 text-sm mb-4 max-w-xs">{banner.description}</p>
    )}
    <div class="mt-auto">
      <Button href={banner.link} variant="primary" size="sm">
        Shop Now
      </Button>
    </div>
  </div>
</a>
