---
import { Heart, Eye, ArrowRightLeft, ShoppingCart } from '@lucide/astro';
import type { Product } from '../../types';
import Badge from '../ui/Badge.astro';

export interface Props {
  product: Product;
}

const { product } = Astro.props;

const badgeText: Record<string, string> = {
  sale: 'Sale',
  new: 'New',
  hot: 'Hot',
  'sold-out': 'Sold Out',
};
---

<div class="group relative bg-white rounded-lg overflow-hidden transition-all duration-300 hover:shadow-hover">
  <!-- Image -->
  <a href={`/product/${product.slug}`} class="relative block aspect-square overflow-hidden bg-light border border-dashed border-border/50 m-3 rounded-lg">
    <img
      src={product.image}
      alt={product.name}
      class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 p-4"
      loading="lazy"
    />
    {product.hoverImage && (
      <img
        src={product.hoverImage}
        alt={product.name}
        class="absolute inset-0 w-full h-full object-cover opacity-0 transition-opacity duration-500 group-hover:opacity-100 p-4"
        loading="lazy"
      />
    )}
    {product.badge && (
      <div class="absolute top-5 left-5">
        <Badge text={badgeText[product.badge]} type={product.badge} />
      </div>
    )}

    <!-- Actions -->
    <div class="product-actions">
      <button
        type="button"
        class="w-9 h-9 bg-white text-heading rounded-full shadow-card flex items-center justify-center hover:bg-primary hover:text-white transition-colors"
        aria-label="Add to wishlist"
      >
        <Heart size={16} />
      </button>
      <button
        type="button"
        class="w-9 h-9 bg-white text-heading rounded-full shadow-card flex items-center justify-center hover:bg-primary hover:text-white transition-colors"
        aria-label="Quick view"
      >
        <Eye size={16} />
      </button>
      <button
        type="button"
        class="w-9 h-9 bg-white text-heading rounded-full shadow-card flex items-center justify-center hover:bg-primary hover:text-white transition-colors"
        aria-label="Compare"
      >
        <ArrowRightLeft size={16} />
      </button>
    </div>
  </a>

  <!-- Content -->
  <div class="px-5 pb-5">
    <div class="flex items-center gap-2 mb-2">
      <span class="text-lg font-bold text-primary">${product.price.toFixed(2)}</span>
      {product.oldPrice && (
        <span class="text-sm text-muted line-through">${product.oldPrice.toFixed(2)}</span>
      )}
    </div>
    <a href={`/product/${product.slug}`} class="block text-sm font-semibold text-heading hover:text-primary transition-colors mb-2 leading-snug">
      {product.name}
    </a>
    <div class="flex items-center gap-1.5">
      <div class="flex items-center">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg width={14} height={14} viewBox="0 0 24 24" fill={i < Math.round(product.rating) ? '#ffcb45' : 'none'} stroke="#ffcb45" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
        ))}
      </div>
      <span class="text-xs text-muted">({product.reviewCount})</span>
    </div>
  </div>

  <!-- Add to Cart (hover) -->
  <div class="absolute bottom-5 left-5 right-5 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-300">
    <button
      type="button"
      data-add-to-cart
      data-product-id={product.id}
      class="inline-flex items-center justify-center gap-2 w-full px-5 py-2.5 bg-accent text-white text-sm font-semibold rounded-pill hover:bg-primary transition-colors"
    >
      <ShoppingCart size={16} />
      <span>Add to Cart</span>
    </button>
  </div>
</div>

<script>
  import { addToCart } from '../../stores/cartStore';
  import { products } from '../../data';

  document.querySelectorAll('[data-add-to-cart]').forEach((button) => {
    button.addEventListener('click', () => {
      const productId = button.getAttribute('data-product-id');
      const product = products.find((p) => p.id === productId);
      if (product) {
        addToCart(product);
      }
    });
  });
</script>
