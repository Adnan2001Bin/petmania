---
export interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center' | 'right';
  class?: string;
}

const { title, subtitle, align = 'center', class: className = '' } = Astro.props;

const alignClass = {
  left: 'text-left',
  center: 'text-center',
  right: 'text-right',
}[align];
---

<div class={`mb-10 ${alignClass} ${className}`}>
  {subtitle && (
    <span class="inline-block text-primary font-semibold text-sm uppercase tracking-wider mb-2">
      {subtitle}
    </span>
  )}
  <h2 class="text-3xl md:text-4xl font-bold text-heading">
    {title}
  </h2>
</div>
