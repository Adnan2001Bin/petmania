---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import AdminTopbar from '../../../components/admin/AdminTopbar.astro';
import ProductTable from '../../../components/admin/ProductTable.astro';
import adminProductsData from '../../../data/admin-products.json';
import type { Product } from '../../../types';
import { Plus, Download, Filter } from '@lucide/astro';

const products: Product[] = adminProductsData;

const inStockCount = products.filter((p) => p.inStock).length;
const onSaleCount = products.filter((p) => p.badge === 'sale').length;
---

<AdminLayout title="Products - Petmania Admin" activeNav="products">
  <AdminSidebar slot="sidebar" activeNav="products" />
  <AdminTopbar
    slot="topbar"
    title="Products"
    subtitle={`${products.length} products · ${inStockCount} in stock · ${onSaleCount} on sale`}
  />

  <!-- Toolbar -->
  <div class="mb-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex flex-wrap items-center gap-2">
      <button
        type="button"
        class="inline-flex items-center gap-2 rounded-xl border border-border bg-white px-4 py-2.5 text-sm font-medium text-heading transition-colors hover:border-primary hover:text-primary"
      >
        <Filter size={16} />
        Filter
      </button>
      <button
        type="button"
        class="inline-flex items-center gap-2 rounded-xl border border-border bg-white px-4 py-2.5 text-sm font-medium text-heading transition-colors hover:border-primary hover:text-primary"
      >
        <Download size={16} />
        Export
      </button>
    </div>
    <button
      type="button"
      class="inline-flex items-center justify-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent"
    >
      <Plus size={18} />
      Add Product
    </button>
  </div>

  <!-- Product fields legend -->
  <div class="mb-6 rounded-2xl border border-border bg-white p-4 shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-wider text-muted">Product Fields</p>
    <div class="mt-3 flex flex-wrap gap-2">
      {
        [
          'id', 'slug', 'name', 'price', 'oldPrice', 'priceRange',
          'rating', 'reviewCount', 'image', 'hoverImage', 'category',
          'tags', 'badge', 'description', 'sku', 'inStock',
        ].map((field) => (
          <span class="rounded-lg bg-light px-2.5 py-1 font-mono text-xs text-body">{field}</span>
        ))
      }
    </div>
  </div>

  <ProductTable products={products} />
</AdminLayout>
