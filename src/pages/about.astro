---
import MainLayout from '../layouts/MainLayout.astro';
import { Heart, Truck, ShieldCheck, Headphones } from '@lucide/astro';

const features = [
  { icon: Heart, title: 'Made with Love', desc: 'Every product is chosen with your pet\'s wellbeing in mind.' },
  { icon: Truck, title: 'Fast Delivery', desc: 'Free shipping on orders over $50 with quick delivery.' },
  { icon: ShieldCheck, title: 'Secure Payment', desc: '100% secure checkout with trusted payment partners.' },
  { icon: Headphones, title: '24/7 Support', desc: 'Our pet experts are here to help you anytime.' },
];
---

<MainLayout title="About Us - Petmania" description="Learn more about Petmania and our mission.">
  <div class="bg-light py-8 border-b border-border">
    <div class="container-main">
      <h1 class="text-3xl md:text-4xl font-bold text-heading mb-2">About Us</h1>
      <nav class="text-sm text-muted">
        <a href="/" class="hover:text-primary">Home</a>
        <span class="mx-2">/</span>
        <span class="text-heading">About</span>
      </nav>
    </div>
  </div>

  <section class="py-16 md:py-20">
    <div class="container-main">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-20">
        <div class="rounded-2xl overflow-hidden">
          <img
            src="/images/hero/hero-1.jpg"
            alt="Happy pets"
            class="w-full h-full object-cover aspect-[4/3]"
          />
        </div>
        <div>
          <span class="text-primary font-semibold text-sm uppercase tracking-wider">Our Story</span>
          <h2 class="text-3xl md:text-4xl font-bold text-heading mt-2 mb-4">We Care About Your Pets</h2>
          <p class="text-body leading-relaxed mb-4">
            Petmania was founded with a simple mission: to provide pet owners with the best products for their beloved companions. From nutritious food to fun toys and essential care items, we curate everything your pet needs.
          </p>
          <p class="text-body leading-relaxed mb-6">
            We believe pets are family. That's why we only stock products from trusted brands that meet our high standards for quality, safety, and sustainability.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((feature) => (
          <div class="bg-white rounded-xl p-6 shadow-card text-center hover:shadow-hover transition-shadow">
            <div class="w-14 h-14 mx-auto mb-4 bg-primary/10 rounded-full flex items-center justify-center text-primary">
              <feature.icon size={28} />
            </div>
            <h3 class="text-lg font-semibold text-heading mb-2">{feature.title}</h3>
            <p class="text-sm text-body">{feature.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
