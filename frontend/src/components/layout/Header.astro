---
import { Search, User, Heart, ShoppingCart, Menu, X, ChevronDown } from '@lucide/astro';
import { menu } from '../../data';
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <div class="container-main py-4">
    <div class="flex items-center justify-between gap-6">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 shrink-0">
        <svg class="w-10 h-10" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="24" cy="24" r="24" fill="#ff782c"/>
          <path d="M14 18c0-2 2-6 4-6s3 3 3 3 1-3 3-3 4 4 4 6c0 4-4 8-7 10-3-2-7-6-7-10z" fill="white"/>
          <circle cx="18" cy="16" r="1.5" fill="#ff782c"/>
          <circle cx="30" cy="16" r="1.5" fill="#ff782c"/>
          <path d="M20 20c1 2 2 3 4 3s3-1 4-3" stroke="#ff782c" stroke-width="1.5" stroke-linecap="round"/>
          <path d="M10 14l4 2M38 14l-4 2M12 10l3 4M36 10l-3 4" stroke="white" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <div class="flex flex-col leading-none">
          <span class="text-[10px] text-primary font-semibold tracking-wide uppercase">petshop</span>
          <span class="text-2xl font-extrabold text-heading tracking-tight">Petmania</span>
        </div>
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-7">
        {menu.map((item, i) => (
          <a
            href={item.href}
            class={`text-sm font-semibold transition-colors flex items-center gap-1 ${
              i === 0
                ? 'text-primary'
                : 'text-heading hover:text-primary'
            }`}
          >
            {item.label}
            <ChevronDown size={14} class="opacity-50" />
          </a>
        ))}
      </nav>

      <!-- Search Bar -->
      <div class="hidden lg:flex flex-1 max-w-md">
        <div class="relative w-full">
          <input
            type="text"
            placeholder="Search products..."
            class="w-full pl-5 pr-12 py-3 text-sm bg-light border border-border rounded-full outline-none transition-all duration-300 placeholder:text-muted focus:border-primary focus:ring-2 focus:ring-primary/20"
          />
          <button
            type="button"
            class="absolute right-1 top-1/2 -translate-y-1/2 w-10 h-10 bg-accent text-white rounded-full flex items-center justify-center hover:bg-primary transition-colors"
            aria-label="Search"
          >
            <Search size={18} />
          </button>
        </div>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3 sm:gap-4">
        <a
          href="/login"
          id="auth-link"
          class="hidden md:inline-flex items-center justify-center w-10 h-10 rounded-full text-heading hover:text-primary transition-colors"
          aria-label="Account"
        >
          <User size={20} />
        </a>
        <a
          href="#"
          id="logout-btn"
          class="hidden md:inline-flex items-center justify-center w-10 h-10 rounded-full text-heading hover:text-primary transition-colors"
          aria-label="Logout"
          style="display: none;"
        >
          <User size={20} />
        </a>

        <a
          href="#"
          class="relative hidden md:inline-flex items-center justify-center w-10 h-10 rounded-full text-heading hover:text-primary transition-colors"
          aria-label="Wishlist"
        >
          <Heart size={20} />
          <span class="absolute -top-0.5 -right-0.5 w-5 h-5 bg-primary text-white text-[10px] font-bold rounded-full flex items-center justify-center">
            0
          </span>
        </a>

        <a
          href="/cart"
          class="relative inline-flex items-center gap-2 text-heading hover:text-primary transition-colors"
          aria-label="Cart"
        >
          <div class="relative">
            <ShoppingCart size={20} />
            <span
              id="cart-count"
              class="absolute -top-1.5 -right-1.5 w-5 h-5 bg-primary text-white text-[10px] font-bold rounded-full flex items-center justify-center"
            >
              0
            </span>
          </div>
          <span id="cart-total-price" class="hidden sm:inline text-sm font-semibold">$0.00</span>
        </a>

        <button
          type="button"
          id="mobile-menu-toggle"
          class="lg:hidden inline-flex items-center justify-center w-10 h-10 rounded-full text-heading hover:text-primary transition-colors"
          aria-label="Open menu"
        >
          <Menu size={22} />
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-50 bg-white transform translate-x-full transition-transform duration-300 lg:hidden flex flex-col"
  >
    <div class="flex items-center justify-between p-4 border-b border-border">
      <a href="/" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-primary rounded-full flex items-center justify-center text-white font-bold">P</div>
        <span class="text-xl font-bold text-heading">Petmania</span>
      </a>
      <button
        type="button"
        id="mobile-menu-close"
        class="inline-flex items-center justify-center w-10 h-10 rounded-full text-heading hover:text-primary transition-colors"
        aria-label="Close menu"
      >
        <X size={22} />
      </button>
    </div>

    <!-- Mobile Search -->
    <div class="p-4 border-b border-border">
      <div class="relative w-full">
        <input
          type="text"
          placeholder="Search products..."
          class="w-full pl-5 pr-12 py-3 text-sm bg-light border border-border rounded-full outline-none transition-all duration-300 placeholder:text-muted focus:border-primary focus:ring-2 focus:ring-primary/20"
        />
        <button
          type="button"
          class="absolute right-1 top-1/2 -translate-y-1/2 w-10 h-10 bg-accent text-white rounded-full flex items-center justify-center hover:bg-primary transition-colors"
          aria-label="Search"
        >
          <Search size={18} />
        </button>
      </div>
    </div>

    <nav class="flex flex-col p-4 gap-1 flex-1">
      {menu.map((item) => (
        <a
          href={item.href}
          class="px-4 py-3 text-base font-medium text-heading hover:bg-light hover:text-primary rounded-lg transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>
    <div class="p-4 border-t border-border">
      <a href="/cart" class="flex items-center gap-3 px-4 py-3 text-base font-medium text-heading hover:bg-light rounded-lg">
        <ShoppingCart size={20} />
        <span>Shopping Cart</span>
        <span id="mobile-cart-count" class="ml-auto w-6 h-6 bg-primary text-white text-xs rounded-full flex items-center justify-center">0</span>
      </a>
    </div>
  </div>
</header>

<script>
  import { cartCount, cartTotal } from '../../stores/cartStore';
  import { isLoggedIn, currentUser, logout } from '../../stores/authStore';

  const countEl = document.getElementById('cart-count');
  const mobileCountEl = document.getElementById('mobile-cart-count');
  const priceEl = document.getElementById('cart-total-price');
  const authLink = document.getElementById('auth-link') as HTMLAnchorElement;
  const logoutBtn = document.getElementById('logout-btn') as HTMLAnchorElement;

  function updateCart() {
    const count = cartCount.get();
    const total = cartTotal.get();
    if (countEl) countEl.textContent = String(count);
    if (mobileCountEl) mobileCountEl.textContent = String(count);
    if (priceEl) priceEl.textContent = `$${total.toFixed(2)}`;
  }

  function updateAuth() {
    const loggedIn = isLoggedIn.get();
    const user = currentUser.get();
    if (loggedIn && user) {
      if (authLink) {
        authLink.href = user.role === 'ADMIN' ? '/admin' : '/account';
        authLink.style.display = '';
      }
      if (logoutBtn) {
        logoutBtn.style.display = '';
      }
    } else {
      if (authLink) {
        authLink.href = '/login';
        authLink.style.display = '';
      }
      if (logoutBtn) {
        logoutBtn.style.display = 'none';
      }
    }
  }

  logoutBtn?.addEventListener('click', (e) => {
    e.preventDefault();
    logout();
    window.location.href = '/';
  });

  cartCount.subscribe(updateCart);
  cartTotal.subscribe(updateCart);
  isLoggedIn.subscribe(updateAuth);
  currentUser.subscribe(updateAuth);
  updateCart();
  updateAuth();

  // Mobile menu toggle
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const closeBtn = document.getElementById('mobile-menu-close');
  const mobileMenu = document.getElementById('mobile-menu');

  function openMenu() {
    mobileMenu?.classList.remove('translate-x-full');
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    mobileMenu?.classList.add('translate-x-full');
    document.body.style.overflow = '';
  }

  toggleBtn?.addEventListener('click', openMenu);
  closeBtn?.addEventListener('click', closeMenu);
</script>
