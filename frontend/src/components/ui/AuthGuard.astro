---
export interface Props {
  requireAuth?: boolean;
  requireAdmin?: boolean;
}

const { requireAuth = true, requireAdmin = false } = Astro.props;
---

<div id="auth-guard" data-require-auth={requireAuth} data-require-admin={requireAdmin}></div>

<script>
  import { checkAuthAccess } from '../../stores/authStore';

  const guard = document.getElementById('auth-guard');
  if (guard) {
    const requireAuth = guard.dataset.requireAuth === 'true';
    const requireAdmin = guard.dataset.requireAdmin === 'true';

    checkAuthAccess({ requireAuth, requireAdmin }).then(({ allowed, redirectTo }) => {
      if (!allowed && redirectTo) {
        window.location.replace(redirectTo);
      }
    });
  }
</script>
