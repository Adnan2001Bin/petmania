---
export interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'accent' | 'outline' | 'white';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
  target?: string;
  rel?: string;
}

const { href, type = 'button', variant = 'primary', size = 'md', class: className = '', target, rel } = Astro.props;

const baseStyles = 'inline-flex items-center justify-center gap-2 font-semibold rounded-pill transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-offset-2';

const variants: Record<string, string> = {
  primary: 'bg-primary text-white hover:bg-heading focus:ring-primary',
  accent: 'bg-accent text-white hover:bg-primary focus:ring-accent',
  outline: 'border-2 border-heading text-heading hover:bg-heading hover:text-white focus:ring-heading',
  white: 'bg-white text-heading hover:bg-primary hover:text-white focus:ring-white',
};

const sizes: Record<string, string> = {
  sm: 'px-5 py-2 text-xs',
  md: 'px-6 py-2.5 text-sm',
  lg: 'px-8 py-3 text-base',
};

const classes = `${baseStyles} ${variants[variant]} ${sizes[size]} ${className}`;
---

{href ? (
  <a href={href} class={classes} target={target} rel={rel}>
    <slot />
  </a>
) : (
  <button type={type} class={classes}>
    <slot />
  </button>
)}
