---
import { X } from '@lucide/astro';
---

<div
  id="category-modal"
  class="hidden fixed inset-0 z-[60] flex items-end justify-center p-4 sm:items-center sm:p-6"
  aria-hidden="true"
>
  <div
    id="category-modal-backdrop"
    class="absolute inset-0 bg-dark/50"
  ></div>

  <div
    role="dialog"
    aria-modal="true"
    aria-labelledby="category-modal-title"
    class="relative max-h-[90vh] w-full max-w-lg overflow-y-auto rounded-xl border border-border bg-white"
  >
    <div class="flex items-center justify-between border-b border-border px-5 py-4">
      <h2 id="category-modal-title" class="text-base font-semibold text-heading">
        Add Category
      </h2>
      <button
        id="modal-close-btn"
        type="button"
        class="flex h-8 w-8 items-center justify-center rounded-lg border border-border text-muted transition-colors hover:border-primary hover:text-primary"
        aria-label="Close modal"
      >
        <X size={16} />
      </button>
    </div>

    <form id="category-form" class="px-5 py-4">
      <div
        id="modal-error"
        class="hidden mb-4 rounded-lg border border-sale/30 bg-sale/5 px-3 py-2 text-sm text-sale"
        role="alert"
      ></div>

      <div class="space-y-4">
        <div>
          <label for="category-animal" class="mb-1.5 block text-sm font-medium text-heading">
            Animal <span class="text-sale">*</span>
          </label>
          <select
            id="category-animal"
            name="animalId"
            required
            class="w-full rounded-lg border border-border bg-white px-3 py-2.5 text-sm text-body outline-none transition-colors focus:border-primary"
          >
            <option value="">Select animal</option>
          </select>
        </div>

        <div id="new-animal-panel" class="hidden space-y-3 rounded-lg border border-border bg-light p-3">
          <div class="flex items-center justify-between gap-2">
            <span class="text-sm font-medium text-heading">New animal</span>
            <button
              id="new-animal-cancel-btn"
              type="button"
              class="flex h-7 w-7 items-center justify-center rounded-md text-muted transition-colors hover:text-primary"
              aria-label="Cancel"
            >
              <X size={14} />
            </button>
          </div>

          <input
            id="new-animal-name"
            type="text"
            maxlength="100"
            placeholder="Name"
            class="w-full rounded-lg border border-border bg-white px-3 py-2 text-sm text-body outline-none transition-colors placeholder:text-muted focus:border-primary"
          />

          <input
            id="new-animal-slug"
            type="text"
            maxlength="100"
            placeholder="Slug"
            class="w-full rounded-lg border border-border bg-white px-3 py-2 text-sm text-body outline-none transition-colors placeholder:text-muted focus:border-primary"
          />

          <input
            id="new-animal-image"
            type="text"
            placeholder="Image URL (optional)"
            class="w-full rounded-lg border border-border bg-white px-3 py-2 text-sm text-body outline-none transition-colors placeholder:text-muted focus:border-primary"
          />

          <div
            id="new-animal-error"
            class="hidden rounded-lg border border-sale/30 bg-sale/5 px-3 py-2 text-xs text-sale"
            role="alert"
          ></div>

          <button
            id="new-animal-add-btn"
            type="button"
            class="inline-flex w-full items-center justify-center rounded-lg bg-accent px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-primary"
          >
            Add Animal
          </button>
        </div>

        <div id="category-type-section">
          <label for="category-type" class="mb-1.5 block text-sm font-medium text-heading">
            Category <span class="text-sale">*</span>
          </label>
          <select
            id="category-type"
            class="w-full rounded-lg border border-border bg-white px-3 py-2.5 text-sm text-body outline-none transition-colors focus:border-primary disabled:cursor-not-allowed disabled:bg-light"
          >
            <option value="">Select type</option>
          </select>
        </div>

        <div id="new-category-type-panel" class="hidden space-y-3 rounded-lg border border-border bg-light p-3">
          <div class="flex items-center justify-between gap-2">
            <span class="text-sm font-medium text-heading">New type</span>
            <button
              id="new-category-type-cancel-btn"
              type="button"
              class="flex h-7 w-7 items-center justify-center rounded-md text-muted transition-colors hover:text-primary"
              aria-label="Cancel"
            >
              <X size={14} />
            </button>
          </div>

          <input
            id="new-category-type-name"
            type="text"
            maxlength="100"
            placeholder="Type name"
            class="w-full rounded-lg border border-border bg-white px-3 py-2 text-sm text-body outline-none transition-colors placeholder:text-muted focus:border-primary"
          />
        </div>

        <div
          id="category-preview"
          class="hidden text-sm font-medium text-heading"
        ></div>

        <div>
          <label for="category-description" class="mb-1.5 block text-sm font-medium text-heading">
            Description
          </label>
          <textarea
            id="category-description"
            name="description"
            rows="2"
            maxlength="500"
            placeholder="Optional"
            class="w-full resize-none rounded-lg border border-border bg-white px-3 py-2.5 text-sm text-body outline-none transition-colors placeholder:text-muted focus:border-primary"
          ></textarea>
        </div>

        <div>
          <label for="category-image" class="mb-1.5 block text-sm font-medium text-heading">
            Image
          </label>
          <input
            id="category-image"
            name="image"
            type="text"
            placeholder="URL (optional)"
            class="w-full rounded-lg border border-border bg-white px-3 py-2.5 text-sm text-body outline-none transition-colors placeholder:text-muted focus:border-primary"
          />
        </div>
      </div>

      <div class="mt-6 flex flex-col-reverse gap-2 border-t border-border pt-4 sm:flex-row sm:justify-end">
        <button
          id="modal-cancel-btn"
          type="button"
          class="inline-flex items-center justify-center rounded-lg border border-border px-4 py-2.5 text-sm font-medium text-heading transition-colors hover:border-primary hover:text-primary"
        >
          Cancel
        </button>
        <button
          id="modal-submit-btn"
          type="submit"
          class="inline-flex items-center justify-center rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent"
        >
          Create Category
        </button>
      </div>
    </form>
  </div>
</div>
