---
import { Menu, Bell, Search, User } from '@lucide/astro';

export interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<header class="sticky top-0 z-30 shrink-0 border-b border-border bg-white">
  <div class="flex h-16 items-center justify-between gap-4 px-4 sm:px-6 lg:px-8">
    <div class="flex min-w-0 flex-1 items-center gap-3 sm:gap-4">
      <button
        id="sidebar-toggle"
        type="button"
        class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-border text-heading transition-colors hover:border-primary hover:text-primary lg:hidden"
        aria-label="Open sidebar"
      >
        <Menu size={20} />
      </button>
      <div class="min-w-0">
        <h1 class="text-lg font-semibold text-heading sm:text-xl">{title}</h1>
        {subtitle && (
          <p class="mt-0.5 line-clamp-2 text-xs text-muted sm:text-sm">{subtitle}</p>
        )}
      </div>
    </div>

    <div class="flex shrink-0 items-center gap-2 sm:gap-3">
      <div class="hidden items-center gap-2 rounded-xl border border-border bg-light px-3 py-2 md:flex">
        <Search size={16} class="shrink-0 text-muted" />
        <input
          type="search"
          placeholder="Search..."
          class="w-28 bg-transparent text-sm text-heading outline-none placeholder:text-muted lg:w-44"
        />
      </div>

      <button
        type="button"
        class="relative flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-border text-heading transition-colors hover:border-primary hover:text-primary"
        aria-label="Notifications"
      >
        <Bell size={18} />
        <span class="absolute right-2 top-2 h-2 w-2 rounded-full bg-sale"></span>
      </button>

      <div class="flex shrink-0 items-center gap-2 rounded-xl border border-border bg-light py-1.5 pl-1.5 pr-3">
        <span class="flex h-8 w-8 items-center justify-center rounded-lg bg-accent text-white">
          <User size={16} />
        </span>
        <div class="hidden sm:block">
          <p class="text-xs font-semibold leading-tight text-heading">Admin</p>
          <p class="text-[10px] text-muted">Store Manager</p>
        </div>
      </div>
    </div>
  </div>
</header>
