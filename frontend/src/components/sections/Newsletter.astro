---
import { Send } from '@lucide/astro';
import Input from '../ui/Input.astro';
import Button from '../ui/Button.astro';
---

<section class="py-16 md:py-20 bg-accent">
  <div class="container-main">
    <div class="flex flex-col lg:flex-row items-center justify-between gap-8">
      <div class="text-center lg:text-left">
        <h2 class="text-2xl md:text-3xl font-bold text-white mb-2">Join Our Newsletter</h2>
        <p class="text-white/80">Subscribe to receive updates, access to exclusive deals, and more.</p>
      </div>
      <form class="w-full max-w-md flex gap-2" onsubmit="event.preventDefault();">
        <Input
          type="email"
          name="newsletter"
          placeholder="Enter your email address"
          required
          inputClass="!rounded-full !bg-white/10 !border-white/10 !text-white placeholder:!text-white/60"
        />
        <Button type="submit" variant="primary" class="!px-6 shrink-0">
          <Send size={18} />
          <span class="hidden sm:inline">Subscribe</span>
        </Button>
      </form>
    </div>
  </div>
</section>
