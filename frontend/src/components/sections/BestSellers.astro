---
import { fetchPublicProducts } from '../../lib/products';
import SectionHeading from '../ui/SectionHeading.astro';
import ProductCard from '../cards/ProductCard.astro';
import { ChevronRight } from '@lucide/astro';

let bestSellers = [];
try {
  const products = await fetchPublicProducts({ limit: 10 });
  bestSellers = products
    .sort((a, b) => b.reviewCount - a.reviewCount)
    .slice(0, 10);
} catch {
  bestSellers = [];
}
---

<section class="py-16 md:py-20">
  <div class="container-main">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-10">
      <SectionHeading title="Best Seller Products" align="left" class="mb-0" />
      <a href="/shop" class="inline-flex items-center gap-2 text-sm font-semibold text-heading hover:text-primary transition-colors self-start sm:self-auto">
        View All Products
        <span class="w-8 h-8 bg-accent text-white rounded-full flex items-center justify-center hover:bg-primary transition-colors">
          <ChevronRight size={16} />
        </span>
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 xl:grid-cols-5 gap-6">
      {bestSellers.map((product) => (
        <ProductCard product={product} />
      ))}
    </div>
  </div>
</section>
