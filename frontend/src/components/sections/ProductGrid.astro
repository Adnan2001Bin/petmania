---
import type { Product } from "../../types";
import SectionHeading from "../ui/SectionHeading.astro";
import ProductCard from "../cards/ProductCard.astro";
import BrushDivider from "../ui/BrushDivider.astro";

export interface Props {
  title: string;
  subtitle?: string;
  products: Product[];
  showViewAll?: boolean;
}

const { title, subtitle, products, showViewAll = false } = Astro.props;
---

<div>
  <section class="py-12 md:py-16">
    <div class="container-main">
      <div
        class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4"
      >
        <SectionHeading
          title={title}
          subtitle={subtitle}
          align="left"
          class="mb-0"
        />
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    </div>
  </section>
</div>
