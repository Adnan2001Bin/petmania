---
import aboutData from '../../../data/about.json';
import BrushDivider from '../../ui/BrushDivider.astro';

const { services } = aboutData;
---

<section id="services" class="bg-[#f9f1f1] pb-0">
<div class="relative z-10 -mt-12 md:-mt-16 rotate-180">
  <BrushDivider class="text-white" flip />
</div>

  <div class="container-main text-center mb-12 md:mb-16 pt-6 md:pt-8">
    <span class="inline-block text-primary font-bold text-xs md:text-sm uppercase tracking-[0.15em] mb-3">
      {services.subtitle}
    </span>
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold text-heading">
      {services.title}
    </h2>
  </div>

  <div class="container-main pb-16 md:pb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">
      {services.items.map((item) => (
        <div class="bg-white px-8 py-10 md:px-10 md:py-12 text-center shadow-[0_0_30px_rgba(0,0,0,0.06)] hover:shadow-hover transition-shadow duration-300">
          <div class="relative inline-flex items-center justify-center mb-6">
            <!-- Paw prints -->
            <svg class="absolute -top-2 -right-4 w-5 h-5" style={`color: ${item.color}`} viewBox="0 0 24 24" fill="currentColor" opacity="0.6">
              <ellipse cx="6" cy="8" rx="2.5" ry="3"/><ellipse cx="12" cy="6" rx="2.5" ry="3"/><ellipse cx="18" cy="8" rx="2.5" ry="3"/>
            </svg>
            <svg class="absolute -top-4 right-0 w-4 h-4" style={`color: ${item.color}`} viewBox="0 0 24 24" fill="currentColor" opacity="0.4">
              <ellipse cx="6" cy="8" rx="2.5" ry="3"/><ellipse cx="12" cy="6" rx="2.5" ry="3"/><ellipse cx="18" cy="8" rx="2.5" ry="3"/>
            </svg>

            <!-- Blob icon -->
            <div
              class="about-blob w-28 h-28 flex items-center justify-center"
              style={`background-color: ${item.color}`}
            >
              {item.icon === 'shield' && (
                <svg class="w-12 h-12 text-white" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M24 4L8 10v12c0 10 7 16 16 20 9-4 16-10 16-20V10L24 4z" stroke-linejoin="round"/>
                  <ellipse cx="24" cy="24" rx="4" ry="5" fill="currentColor" stroke="none"/>
                  <circle cx="20" cy="20" r="1.5" fill="currentColor" stroke="none"/>
                  <circle cx="28" cy="20" r="1.5" fill="currentColor" stroke="none"/>
                  <circle cx="22" cy="27" r="1.5" fill="currentColor" stroke="none"/>
                  <circle cx="26" cy="27" r="1.5" fill="currentColor" stroke="none"/>
                </svg>
              )}
              {item.icon === 'healthcare' && (
                <svg class="w-12 h-12 text-white" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="10" y="18" width="28" height="16" rx="3" stroke-linejoin="round"/>
                  <path d="M16 18v-4a4 4 0 018 0v4" stroke-linecap="round"/>
                  <path d="M10 26h28" stroke-linecap="round"/>
                  <circle cx="34" cy="14" r="2" fill="currentColor" stroke="none"/>
                  <ellipse cx="34" cy="18" rx="3" ry="4" fill="currentColor" stroke="none"/>
                </svg>
              )}
              {item.icon === 'tag' && (
                <svg class="w-12 h-12 text-white" viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="24" cy="24" r="14"/>
                  <circle cx="24" cy="24" r="6" fill="currentColor" stroke="none"/>
                  <circle cx="24" cy="10" r="2" fill="currentColor" stroke="none"/>
                </svg>
              )}
            </div>
          </div>
          <h3 class="text-lg font-bold text-heading mb-3">{item.title}</h3>
          <p class="text-sm text-body leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>

  <BrushDivider class="text-white" flip />
</section>
