---
import type { Banner } from '../../types';
import { ChevronRight } from '@lucide/astro';

export interface Props {
  banner: Banner;
  class?: string;
}

const { banner, class: className = '' } = Astro.props;
---

<a
  href={banner.link}
  class={`group relative block overflow-hidden rounded-xl ${className}`}
>
  <img
    src={banner.image}
    alt={banner.title}
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
    loading="lazy"
  />
  <div class="absolute inset-0 bg-gradient-to-r from-black/50 via-black/10 to-transparent"></div>
  <div class="relative h-full flex flex-col justify-center p-6 md:p-8">
    {banner.subtitle && (
      <span class="inline-block text-white/90 text-sm font-semibold uppercase tracking-wider mb-2">
        {banner.subtitle}
      </span>
    )}
    <h3 class="text-2xl md:text-3xl font-bold text-white mb-2">{banner.title}</h3>
    {banner.description && (
      <p class="text-white/80 text-sm mb-4 max-w-xs">{banner.description}</p>
    )}
    <div class="mt-auto">
      <span class="inline-flex items-center gap-2 px-6 py-2.5 bg-accent text-white text-sm font-semibold rounded-full hover:bg-primary transition-colors">
        Shop Now
        <span class="w-6 h-6 bg-white/20 rounded-full flex items-center justify-center">
          <ChevronRight size={14} />
        </span>
      </span>
    </div>
  </div>
</a>
