---
import { Heart, Eye, ArrowRightLeft, ShoppingCart } from '@lucide/astro';
import type { Product } from '../../types';
import Badge from '../ui/Badge.astro';

export interface Props {
  product: Product;
}

const { product } = Astro.props;
---

<div class="group flex h-full flex-col overflow-hidden rounded-lg bg-white transition-all duration-300 hover:shadow-hover">
  <!-- Image -->
  <a href={`/product/${product.slug}`} class="product-card-image relative block w-full shrink-0 overflow-hidden bg-light">
    <img
      src={product.image}
      alt={product.name}
      class="product-card-img absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
      loading="lazy"
    />
    {product.oldPrice && (
      <div class="absolute top-5 left-5">
        <Badge text="Sale" type="sale" />
      </div>
    )}

    <!-- Actions -->
    <div class="product-actions">
      <button
        type="button"
        class="w-9 h-9 bg-white text-heading rounded-full shadow-card flex items-center justify-center hover:bg-primary hover:text-white transition-colors"
        aria-label="Add to wishlist"
      >
        <Heart size={16} />
      </button>
      <button
        type="button"
        class="w-9 h-9 bg-white text-heading rounded-full shadow-card flex items-center justify-center hover:bg-primary hover:text-white transition-colors"
        aria-label="Quick view"
      >
        <Eye size={16} />
      </button>
      <button
        type="button"
        class="w-9 h-9 bg-white text-heading rounded-full shadow-card flex items-center justify-center hover:bg-primary hover:text-white transition-colors"
        aria-label="Compare"
      >
        <ArrowRightLeft size={16} />
      </button>
    </div>
  </a>

  <!-- Content -->
  <div class="flex flex-1 flex-col px-5 pb-5 pt-4">
    <div class="flex items-center gap-2 mb-2">
      <span class="text-lg font-bold text-primary">${product.price.toFixed(2)}</span>
      {product.oldPrice && (
        <span class="text-sm text-muted line-through">${product.oldPrice.toFixed(2)}</span>
      )}
    </div>
    <a href={`/product/${product.slug}`} class="mb-2 line-clamp-2 min-h-[2.5rem] block text-sm font-semibold text-heading hover:text-primary transition-colors leading-snug">
      {product.name}
    </a>
    <div class="mt-auto flex items-center gap-1.5">
      <div class="flex items-center">
        {Array.from({ length: 5 }).map((_, i) => (
          <svg width={14} height={14} viewBox="0 0 24 24" fill={i < Math.round(product.rating) ? '#ffcb45' : 'none'} stroke="#ffcb45" stroke-width="2">
            <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
          </svg>
        ))}
      </div>
      <span class="text-xs text-muted">({product.reviewCount})</span>
    </div>
  </div>

  <!-- Add to Cart (hover) -->
  <div class="px-5 pb-5">
    <button
      type="button"
      id={`cart-btn-${product.id}`}
      data-add-to-cart
      data-product-id={product.id}
      class="inline-flex items-center justify-center gap-2 w-full px-5 py-2.5 bg-accent text-white text-sm font-semibold rounded-pill opacity-0 transition-all duration-300 group-hover:opacity-100 hover:bg-primary"
    >
      <ShoppingCart size={16} />
      <span>Add to Cart</span>
    </button>
  </div>
</div>

<script define:vars={{ product }}>
  import { addToCart } from '../../stores/cartStore';

  document.getElementById(`cart-btn-${product.id}`)?.addEventListener('click', () => {
    addToCart(product);
  });
</script>
