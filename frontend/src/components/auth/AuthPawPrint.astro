---
export interface Props {
  class?: string;
  tone?: 'soft' | 'solid';
  /** Palm at top, toes pointing down — for top-corner decorations */
  orient?: 'up' | 'down';
}

const { class: className = '', tone = 'soft', orient = 'up' } = Astro.props;
const flipTransform = orient === 'down' ? 'translate(0 120) scale(1 -1)' : undefined;
---

<svg
  class:list={['auth-paw-print', `auth-paw-print--${tone}`, className]}
  viewBox="0 0 100 120"
  fill="none"
  aria-hidden="true"
>
  <g transform={flipTransform}>
    <g class="auth-paw-print__shadows" transform="translate(2.5 3.5)">
      <ellipse cx="50" cy="88" rx="27" ry="23"></ellipse>
      <ellipse cx="23" cy="47" rx="12" ry="14" transform="rotate(-12 23 47)"></ellipse>
      <ellipse cx="39" cy="31" rx="11" ry="13" transform="rotate(-6 39 31)"></ellipse>
      <ellipse cx="57" cy="31" rx="11" ry="13" transform="rotate(6 57 31)"></ellipse>
      <ellipse cx="73" cy="47" rx="12" ry="14" transform="rotate(12 73 47)"></ellipse>
    </g>

    <g class="auth-paw-print__pads">
      <ellipse cx="50" cy="88" rx="27" ry="23"></ellipse>
      <ellipse cx="23" cy="47" rx="12" ry="14" transform="rotate(-12 23 47)"></ellipse>
      <ellipse cx="39" cy="31" rx="11" ry="13" transform="rotate(-6 39 31)"></ellipse>
      <ellipse cx="57" cy="31" rx="11" ry="13" transform="rotate(6 57 31)"></ellipse>
      <ellipse cx="73" cy="47" rx="12" ry="14" transform="rotate(12 73 47)"></ellipse>
    </g>
  </g>
</svg>
