---
export interface Props {
  formTitle: string;
  formSubtitle: string;
  panelTitle: string;
  panelDescription: string;
}

const { formTitle, formSubtitle, panelTitle, panelDescription } = Astro.props;
---

<div class="auth-page">
  <!-- Organic blobs: top-left + bottom-right -->
  <svg
    class="auth-blob auth-blob--top-left"
    viewBox="0 0 580 520"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M80 60C200 -30 420 10 500 150C580 290 520 470 360 510C200 550 20 470 10 320C0 170 0 90 80 60Z"
      fill="var(--color-primary)"
    ></path>
  </svg>

  <svg
    class="auth-blob auth-blob--bottom-right"
    viewBox="0 0 540 500"
    fill="none"
    aria-hidden="true"
  >
    <path
      d="M40 100C120 20 320 40 420 130C520 220 540 360 450 450C360 540 160 520 60 420C-40 320 -20 180 40 100Z"
      fill="var(--color-accent)"
    ></path>
  </svg>

  <div class="auth-card">
    <div class="auth-card__inner">
      <aside class="auth-brand">
        <div class="auth-dots auth-dots--light absolute right-7 top-7 h-[88px] w-[88px]" aria-hidden="true"></div>
        <div class="auth-dots auth-dots--light absolute bottom-36 left-5 h-[72px] w-[72px]" aria-hidden="true"></div>

        <div class="relative z-10">
          <a href="/" class="inline-flex items-center gap-3 no-underline text-inherit">
            <span class="auth-logo-mark">
              <svg class="h-[26px] w-[26px] text-white" viewBox="0 0 48 48" fill="currentColor" aria-hidden="true">
                <circle cx="14" cy="14" r="3"></circle>
                <circle cx="24" cy="10" r="3.5"></circle>
                <circle cx="34" cy="14" r="3"></circle>
                <circle cx="9" cy="22" r="2.5"></circle>
                <circle cx="39" cy="22" r="2.5"></circle>
                <ellipse cx="24" cy="32" rx="7" ry="5.5"></ellipse>
              </svg>
            </span>
            <span>
              <span class="auth-brand-eyebrow">petshop</span>
              <span class="auth-brand-name">Petmania</span>
              <span class="auth-brand-tagline">Happy Pets, Happy Life</span>
            </span>
          </a>

          <h1 class="auth-brand-title">{panelTitle}</h1>
          <p class="auth-brand-text">{panelDescription}</p>
        </div>

        <div class="auth-illustration hidden sm:flex" aria-hidden="true">
          <div class="auth-illustration__backdrop">
            <img
              src="/images/auth/auth-illustration.svg"
              alt=""
              class="auth-illustration__image"
              width="280"
              height="190"
              loading="lazy"
            />
          </div>
        </div>
      </aside>

      <section class="auth-form-panel">
        <div class="auth-dots auth-dots--accent absolute right-7 top-7 h-[76px] w-[76px]" aria-hidden="true"></div>
        <div class="auth-dots auth-dots--muted absolute bottom-8 right-10 h-[64px] w-[64px]" aria-hidden="true"></div>
        <div class="auth-dots auth-dots--primary absolute bottom-24 left-6 h-[52px] w-[52px] hidden sm:block" aria-hidden="true"></div>

        <div class="auth-form-inner relative z-10">
          <h2 class="auth-title">{formTitle}</h2>
          <p class="auth-subtitle">{formSubtitle}</p>

          <div class="mt-7">
            <slot />
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
