---
import AuthPawPrint from './AuthPawPrint.astro';

export interface Props {
  formTitle: string;
  formSubtitle: string;
  panelTitle: string;
  panelDescription: string;
}

const { formTitle, formSubtitle, panelTitle, panelDescription } = Astro.props;
---

<div class="auth-page">
  <div class="auth-paws" aria-hidden="true">
    <AuthPawPrint tone="soft" orient="down" class="auth-paw auth-paw--1" />
    <AuthPawPrint tone="soft" orient="down" class="auth-paw auth-paw--2" />
    <AuthPawPrint tone="soft" class="auth-paw auth-paw--3" />
    <AuthPawPrint tone="soft" class="auth-paw auth-paw--4" />
  </div>

  <div class="auth-card">
    <div class="auth-card__inner">
      <aside class="auth-brand">
        <div class="auth-dots auth-dots--light pointer-events-none absolute right-7 top-7 h-[88px] w-[88px]" aria-hidden="true"></div>
        <div class="auth-dots auth-dots--light pointer-events-none absolute bottom-36 left-5 h-[72px] w-[72px]" aria-hidden="true"></div>

        <div class="relative z-10">
          <a href="/" class="inline-flex items-center gap-3 no-underline text-inherit">
            <span class="auth-logo-mark">
              <svg class="h-[26px] w-[26px] text-white" viewBox="0 0 48 48" fill="currentColor" aria-hidden="true">
                <circle cx="14" cy="14" r="3"></circle>
                <circle cx="24" cy="10" r="3.5"></circle>
                <circle cx="34" cy="14" r="3"></circle>
                <circle cx="9" cy="22" r="2.5"></circle>
                <circle cx="39" cy="22" r="2.5"></circle>
                <ellipse cx="24" cy="32" rx="7" ry="5.5"></ellipse>
              </svg>
            </span>
            <span>
              <span class="auth-brand-eyebrow">petshop</span>
              <span class="auth-brand-name">Petmania</span>
              <span class="auth-brand-tagline">Happy Pets, Happy Life</span>
            </span>
          </a>

          <h1 class="auth-brand-title">{panelTitle}</h1>
          <p class="auth-brand-text">{panelDescription}</p>
        </div>

        <div class="auth-illustration hidden sm:flex" aria-hidden="true">
          <div class="auth-illustration__backdrop">
            <img
              src="/images/auth/auth-illustration.svg"
              alt=""
              class="auth-illustration__image"
              width="280"
              height="190"
              loading="lazy"
            />
          </div>
        </div>
      </aside>

      <section class="auth-form-panel">
        <div class="auth-dots auth-dots--accent pointer-events-none absolute right-7 top-7 h-[76px] w-[76px]" aria-hidden="true"></div>
        <div class="auth-dots auth-dots--muted pointer-events-none absolute bottom-8 right-10 h-[64px] w-[64px]" aria-hidden="true"></div>
        <div class="auth-dots auth-dots--primary pointer-events-none absolute bottom-24 left-6 h-[52px] w-[52px] hidden sm:block" aria-hidden="true"></div>

        <div class="auth-form-inner relative z-10">
          <h2 class="auth-title">{formTitle}</h2>
          <p class="auth-subtitle">{formSubtitle}</p>

          <div class="mt-7">
            <slot />
          </div>
        </div>
      </section>
    </div>
  </div>
</div>
