---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import AdminTopbar from '../../../components/admin/AdminTopbar.astro';
import CategoryModal from '../../../components/admin/CategoryModal.astro';
import ConfirmDialog from '../../../components/admin/ConfirmDialog.astro';
import AdminToast from '../../../components/admin/AdminToast.astro';
import { Plus } from '@lucide/astro';
---

<AdminLayout title="Categories - Petmania Admin" activeNav="categories">
  <AdminSidebar slot="sidebar" activeNav="categories" />
  <AdminTopbar
    slot="topbar"
    title="Categories"
    subtitle="Loading categories..."
    subtitleId="categories-subtitle"
  />

  <div id="categories-page">
    <div
      id="categories-error"
      class="hidden mb-4 rounded-lg border border-sale/30 bg-sale/5 px-4 py-3 text-sm text-sale"
      role="alert"
    ></div>

    <div id="categories-loading" class="rounded-xl border border-border bg-white px-6 py-16 text-center">
      <div class="mx-auto mb-3 h-8 w-8 animate-spin rounded-full border-2 border-border border-t-primary"></div>
      <p class="text-sm text-muted">Loading categories...</p>
    </div>

    <div id="categories-content" class="hidden">
      <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div class="flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-end">
          <div class="min-w-[180px]">
            <label for="animal-filter" class="mb-1.5 block text-xs font-medium text-muted">
              Filter by animal
            </label>
            <select
              id="animal-filter"
              class="w-full rounded-lg border border-border bg-white px-3 py-2.5 text-sm text-body outline-none transition-colors focus:border-primary"
            >
              <option value="">All animals</option>
            </select>
          </div>
          <div class="min-w-[220px] flex-1 sm:max-w-xs">
            <label for="category-search" class="mb-1.5 block text-xs font-medium text-muted">
              Search categories
            </label>
            <input
              id="category-search"
              type="search"
              placeholder="Search by name or slug..."
              class="w-full rounded-lg border border-border bg-white px-3 py-2.5 text-sm text-body outline-none transition-colors placeholder:text-muted focus:border-primary"
            />
          </div>
        </div>
        <button
          id="add-category-btn"
          type="button"
          class="inline-flex shrink-0 items-center justify-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent"
        >
          <Plus size={18} />
          Add Category
        </button>
      </div>

      <div id="categories-table-wrap" class="hidden overflow-hidden rounded-xl border border-border bg-white">
        <div class="overflow-x-auto">
          <table class="min-w-full text-left text-sm">
            <thead class="border-b border-border bg-light">
              <tr>
                <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wide text-muted">Image</th>
                <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wide text-muted">Name</th>
                <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wide text-muted">Slug</th>
                <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wide text-muted">Animal</th>
                <th class="px-4 py-3 text-xs font-semibold uppercase tracking-wide text-muted">Products</th>
                <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-muted">Actions</th>
              </tr>
            </thead>
            <tbody id="categories-tbody"></tbody>
          </table>
        </div>
      </div>

      <div
        id="categories-empty"
        class="hidden rounded-xl border border-dashed border-border bg-white px-6 py-16 text-center"
      >
        <p id="categories-empty-title" class="text-base font-medium text-heading">No categories yet</p>
        <p class="mt-1 text-sm text-muted">
          Create your first category to organize products by animal type.
        </p>
        <button
          type="button"
          class="add-category-empty-btn mt-5 inline-flex items-center gap-2 rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-accent"
        >
          <Plus size={16} />
          Add Category
        </button>
      </div>
    </div>
  </div>

  <CategoryModal />
  <ConfirmDialog />
  <AdminToast />
</AdminLayout>

<script>
  import { initCategoriesPage } from '../../../scripts/admin-categories';

  initCategoriesPage();

  document.querySelectorAll('.add-category-empty-btn').forEach((button) => {
    button.addEventListener('click', () => {
      document.getElementById('add-category-btn')?.click();
    });
  });
</script>
