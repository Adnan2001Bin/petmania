---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import AdminSidebar from '../../../components/admin/AdminSidebar.astro';
import AdminTopbar from '../../../components/admin/AdminTopbar.astro';
import { ShoppingCart, Clock } from '@lucide/astro';

const demoOrders = [
  { id: '#ORD-1042', customer: 'Sarah Johnson', items: 3, total: '$142.38', status: 'Completed', date: 'Jun 17, 2026' },
  { id: '#ORD-1041', customer: 'Mike Chen', items: 1, total: '$59.99', status: 'Processing', date: 'Jun 17, 2026' },
  { id: '#ORD-1040', customer: 'Emma Wilson', items: 5, total: '$287.50', status: 'Shipped', date: 'Jun 16, 2026' },
  { id: '#ORD-1039', customer: 'James Brown', items: 2, total: '$34.98', status: 'Pending', date: 'Jun 16, 2026' },
  { id: '#ORD-1038', customer: 'Lisa Davis', items: 4, total: '$198.20', status: 'Completed', date: 'Jun 15, 2026' },
];

const statusStyles: Record<string, string> = {
  Completed: 'bg-success/10 text-success',
  Processing: 'bg-primary/10 text-primary',
  Shipped: 'bg-accent/10 text-accent',
  Pending: 'bg-star/20 text-heading',
};
---

<AdminLayout title="Orders - Petmania Admin" activeNav="orders">
  <AdminSidebar slot="sidebar" activeNav="orders" />
  <AdminTopbar slot="topbar" title="Orders" subtitle="Demo order data for preview" />

  <div class="overflow-hidden rounded-2xl border border-border bg-white shadow-sm">
    <div class="hidden lg:block">
      <table class="w-full text-left text-sm">
        <thead>
          <tr class="border-b border-border bg-light/80">
            <th class="px-5 py-4 font-semibold text-heading">Order ID</th>
            <th class="px-5 py-4 font-semibold text-heading">Customer</th>
            <th class="px-5 py-4 font-semibold text-heading">Items</th>
            <th class="px-5 py-4 font-semibold text-heading">Total</th>
            <th class="px-5 py-4 font-semibold text-heading">Status</th>
            <th class="px-5 py-4 font-semibold text-heading">Date</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          {
            demoOrders.map((order) => (
              <tr class="transition-colors hover:bg-light/50">
                <td class="px-5 py-4 font-mono text-xs font-medium text-accent">{order.id}</td>
                <td class="px-5 py-4 font-medium text-heading">{order.customer}</td>
                <td class="px-5 py-4 text-body">{order.items}</td>
                <td class="px-5 py-4 font-semibold text-heading">{order.total}</td>
                <td class="px-5 py-4">
                  <span class:list={['rounded-lg px-2.5 py-1 text-xs font-medium', statusStyles[order.status]]}>
                    {order.status}
                  </span>
                </td>
                <td class="px-5 py-4 text-muted">{order.date}</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>

    <div class="divide-y divide-border lg:hidden">
      {
        demoOrders.map((order) => (
          <div class="p-4">
            <div class="flex items-center justify-between">
              <span class="font-mono text-xs font-medium text-accent">{order.id}</span>
              <span class:list={['rounded-lg px-2 py-0.5 text-xs font-medium', statusStyles[order.status]]}>
                {order.status}
              </span>
            </div>
            <p class="mt-2 font-medium text-heading">{order.customer}</p>
            <div class="mt-2 flex items-center justify-between text-sm">
              <span class="text-muted">{order.items} items</span>
              <span class="font-semibold text-heading">{order.total}</span>
            </div>
            <p class="mt-1 flex items-center gap-1 text-xs text-muted">
              <Clock size={12} />
              {order.date}
            </p>
          </div>
        ))
      }
    </div>
  </div>

  <p class="mt-6 flex items-center justify-center gap-2 text-sm text-muted">
    <ShoppingCart size={16} />
    Order management coming soon
  </p>
</AdminLayout>
