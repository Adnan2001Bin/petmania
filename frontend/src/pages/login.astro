---
import AuthLayout from '../layouts/AuthLayout.astro';
import AuthShell from '../components/auth/AuthShell.astro';
import AuthField from '../components/auth/AuthField.astro';
import AuthSubmit from '../components/auth/AuthSubmit.astro';
---

<AuthLayout title="Login - Petmania" description="Sign in to your Petmania account.">
  <AuthShell
    formTitle="Login"
    formSubtitle="Please sign in to get started."
    panelTitle="Welcome Back to Your Pet's Best Life"
    panelDescription="Sign in to Petmania and keep giving your furry companion the love, care, and happiness they deserve."
  >
    <form id="login-form" class="auth-form-grid">
      <div id="login-error" class="auth-error hidden auth-field--full"></div>

      <AuthField
        id="email"
        label="Email Address"
        type="email"
        icon="mail"
        placeholder="Email Address"
        required
        autocomplete="email"
        class="auth-field--full"
      />

      <AuthField
        id="password"
        label="Password"
        type="password"
        icon="lock"
        placeholder="Password"
        required
        autocomplete="current-password"
        class="auth-field--full"
      />

      <p class="auth-link auth-field--full">
        Don't have an account? <a href="/register">Register</a>
      </p>

      <div class="auth-field--full">
        <AuthSubmit id="login-btn" label="Login" />
      </div>
    </form>
  </AuthShell>
</AuthLayout>

<script>
  import { login, getPostLoginRedirect, currentUser, waitForAuth } from '../stores/authStore';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errorEl = document.getElementById('login-error')!;
  const btn = document.getElementById('login-btn') as HTMLButtonElement;
  const btnLabel = btn.querySelector('span')!;

  waitForAuth().then(() => {
    const user = currentUser.get();
    if (user) {
      window.location.replace(getPostLoginRedirect(user));
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    btn.disabled = true;
    btnLabel.textContent = 'Signing in...';

    const email = (document.getElementById('email') as HTMLInputElement).value;
    const password = (document.getElementById('password') as HTMLInputElement).value;

    try {
      const data = await login(email, password);
      window.location.href = getPostLoginRedirect(data.user);
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : 'Login failed';
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btnLabel.textContent = 'Login';
    }
  });
</script>
