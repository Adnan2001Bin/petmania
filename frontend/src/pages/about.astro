---
import MainLayout from '../layouts/MainLayout.astro';
import AboutHero from '../components/sections/about/AboutHero.astro';
import AboutServices from '../components/sections/about/AboutServices.astro';
import AboutTestimonial from '../components/sections/about/AboutTestimonial.astro';
import AboutTeam from '../components/sections/about/AboutTeam.astro';
import AboutBrands from '../components/sections/about/AboutBrands.astro';
import ScrollToTop from '../components/ui/ScrollToTop.astro';
---

<MainLayout title="About Us - Petmania" description="Learn more about Petmania and our mission to provide the best pet care.">
  <AboutHero />
  <AboutServices />
  <AboutTestimonial />
  <AboutTeam />
  <AboutBrands />
  <ScrollToTop />
</MainLayout>

<style is:global>
  .about-blob {
    border-radius: 40% 60% 55% 45% / 55% 45% 55% 45%;
  }
</style>
