---
import MainLayout from '../layouts/MainLayout.astro';
import { LayoutGrid, List, ChevronRight, ChevronLeft } from '@lucide/astro';

const tags = ['Food', 'Toys', 'Treats', 'Collar', 'Grooming', 'Beds', 'Bowl', 'Organic'];
---

<MainLayout title="Shop - Petmania" description="Browse our wide range of premium pet products.">
  <!-- Promo Banners -->
  <section class="py-6">
    <div class="container-main">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <a href="/shop" class="group relative overflow-hidden rounded-2xl h-64 md:h-72 bg-gradient-to-br from-primary via-primary/90 to-primary/70">
          <div class="absolute inset-0 bg-gradient-to-r from-black/20 to-transparent"></div>
          <div class="relative z-10 h-full flex flex-col justify-center p-8">
            <span class="text-white/90 text-sm font-semibold uppercase tracking-wider mb-1">Dog Supplies</span>
            <div class="flex items-baseline gap-1 mb-4">
              <span class="text-6xl md:text-7xl font-extrabold text-white">25</span>
              <span class="text-2xl md:text-3xl font-bold text-white">%</span>
              <span class="text-xl md:text-2xl font-bold text-white">Off</span>
            </div>
            <div class="bg-accent/90 inline-flex items-center gap-2 px-4 py-2 rounded-full w-fit">
              <span class="text-white font-semibold text-sm">Hotline Order</span>
            </div>
            <p class="text-white/80 text-2xl font-bold mt-3">(877) 123-4567</p>
          </div>
          <div class="absolute right-0 bottom-0 w-1/2 h-full">
            <img src="/images/products/product-1.jpg" alt="Dog Supplies" class="w-full h-full object-cover rounded-tl-full opacity-80" />
          </div>
        </a>

        <a href="/shop" class="group relative overflow-hidden rounded-2xl h-64 md:h-72 bg-gradient-to-br from-accent via-accent/90 to-accent/70">
          <div class="absolute inset-0 bg-gradient-to-r from-black/20 to-transparent"></div>
          <div class="relative z-10 h-full flex flex-col justify-center p-8">
            <span class="text-white/90 text-sm font-semibold uppercase tracking-wider mb-1">Gift For Pet</span>
            <h3 class="text-3xl md:text-4xl font-extrabold text-white leading-tight mb-4">Premium<br/>Cat Food</h3>
            <p class="text-2xl font-bold">
              <span class="text-white">Save </span>
              <span class="text-primary text-3xl font-extrabold">30%</span>
            </p>
          </div>
          <div class="absolute right-0 bottom-0 w-1/2 h-full">
            <img src="/images/products/product-2.jpg" alt="Premium Cat Food" class="w-full h-full object-cover rounded-tl-full opacity-80" />
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="py-4">
    <div class="container-main">
      <nav class="text-sm text-muted flex items-center gap-2">
        <a href="/" class="hover:text-primary transition-colors">Home Page</a>
        <ChevronRight size={14} />
        <span class="text-heading font-medium">Shop</span>
      </nav>
    </div>
  </section>

  <section class="pb-16">
    <div class="container-main">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">
        <h1 class="text-2xl md:text-3xl font-bold text-heading">Shop</h1>
        <div class="flex items-center gap-6">
          <div class="flex items-center gap-2">
            <button type="button" class="w-9 h-9 flex items-center justify-center rounded bg-primary text-white" aria-label="Grid view">
              <LayoutGrid size={18} />
            </button>
            <button type="button" class="w-9 h-9 flex items-center justify-center rounded text-muted hover:text-heading hover:bg-light transition-colors" aria-label="List view">
              <List size={18} />
            </button>
          </div>
          <select id="shop-sort" class="px-4 py-2.5 text-sm border border-border rounded-lg outline-none focus:border-primary bg-white cursor-pointer">
            <option value="default">Default sorting</option>
            <option value="popularity">Sort by popularity</option>
            <option value="rating">Sort by average rating</option>
            <option value="price-asc">Price: low to high</option>
            <option value="price-desc">Price: high to low</option>
          </select>
          <p id="shop-results-count" class="text-sm text-muted hidden md:block">Loading products...</p>
        </div>
      </div>

      <div class="flex flex-col lg:flex-row gap-8">
        <aside class="w-full lg:w-72 shrink-0 space-y-8">
          <div id="shop-category-section">
            <h3 class="text-lg font-bold text-heading mb-4">Product Categories</h3>
            <label for="shop-animal-filter" class="mb-1.5 block text-xs font-medium text-muted">
              Animal
            </label>
            <select
              id="shop-animal-filter"
              class="mb-4 w-full rounded-lg border border-border bg-white px-3 py-2.5 text-sm text-body outline-none transition-colors focus:border-primary"
            >
              <option value="">All animals</option>
            </select>
            <ul id="shop-category-list" class="space-y-1">
              <li class="px-3 py-2 text-sm text-muted">Loading categories...</li>
            </ul>
          </div>

          <div>
            <h3 class="text-lg font-bold text-heading mb-4">Filter By Price</h3>
            <div class="px-1">
              <div class="relative mb-4 h-6">
                <div class="absolute top-1/2 h-1 w-full -translate-y-1/2 rounded-full bg-border"></div>
                <div id="price-range-track" class="absolute top-1/2 h-1 -translate-y-1/2 rounded-full bg-accent"></div>
                <input
                  id="price-min"
                  type="range"
                  class="price-range-input absolute inset-x-0 top-1/2 w-full -translate-y-1/2"
                />
                <input
                  id="price-max"
                  type="range"
                  class="price-range-input absolute inset-x-0 top-1/2 w-full -translate-y-1/2"
                />
              </div>
              <div class="mb-4 text-sm text-body">
                <span id="price-range-label">Price: $0 — $0</span>
              </div>
              <div class="flex flex-wrap gap-2">
                <button
                  id="price-filter-btn"
                  type="button"
                  class="inline-flex items-center gap-2 rounded-pill bg-accent px-6 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-primary"
                >
                  Filter
                  <ChevronRight size={16} />
                </button>
                <button
                  id="clear-filters-btn"
                  type="button"
                  class="inline-flex items-center rounded-pill border border-border px-4 py-2.5 text-sm font-medium text-heading transition-colors hover:border-primary hover:text-primary"
                >
                  Clear all
                </button>
              </div>
            </div>
          </div>

          <div>
            <h3 class="text-lg font-bold text-heading mb-4">Best Seller Products</h3>
            <div id="shop-best-sellers">
              <p class="text-sm text-muted">Loading...</p>
            </div>
          </div>

          <div>
            <h3 class="text-lg font-bold text-heading mb-4">Filter By Tags</h3>
            <div class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <button
                  type="button"
                  data-tag={tag.toLowerCase()}
                  class="shop-tag-btn rounded-full border border-border px-4 py-2 text-sm text-body transition-colors hover:border-primary hover:text-primary"
                >
                  {tag}
                </button>
              ))}
            </div>
          </div>
        </aside>

        <div class="flex-1">
          <div id="shop-products-grid" class="grid grid-cols-1 items-stretch sm:grid-cols-2 xl:grid-cols-3 gap-6">
            <div class="col-span-full py-16 text-center text-sm text-muted">Loading products...</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .price-range-input {
    appearance: none;
    height: 0;
    background: transparent;
    pointer-events: none;
  }

  .price-range-input::-webkit-slider-thumb {
    appearance: none;
    pointer-events: auto;
    width: 16px;
    height: 16px;
    border-radius: 9999px;
    border: 2px solid #fff;
    background: #7c3aed;
    box-shadow: 0 1px 4px rgb(0 0 0 / 15%);
    cursor: pointer;
  }

  .price-range-input::-moz-range-thumb {
    pointer-events: auto;
    width: 16px;
    height: 16px;
    border-radius: 9999px;
    border: 2px solid #fff;
    background: #7c3aed;
    box-shadow: 0 1px 4px rgb(0 0 0 / 15%);
    cursor: pointer;
  }
</style>

<script>
  import { initShopPage } from '../scripts/shop-page';

  initShopPage();
</script>
