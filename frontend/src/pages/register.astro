---
import AuthLayout from '../layouts/AuthLayout.astro';
import AuthShell from '../components/auth/AuthShell.astro';
import AuthField from '../components/auth/AuthField.astro';
import AuthSubmit from '../components/auth/AuthSubmit.astro';
---

<AuthLayout title="Register - Petmania" description="Create your Petmania account.">
  <AuthShell
    formTitle="Registration"
    formSubtitle="Please fill up the form to get started."
    panelTitle="Create an Account for Your Pet's Best Life"
    panelDescription="Join Petmania and give your furry companion the love, care, and happiness they deserve."
  >
    <form id="register-form" class="auth-form-grid auth-form-grid--register">
      <div id="register-error" class="auth-error hidden auth-field--full"></div>

      <AuthField
        id="name"
        label="Full Name"
        type="text"
        icon="user"
        placeholder="Full Name"
        required
        autocomplete="name"
      />

      <AuthField
        id="email"
        label="Email Address"
        type="email"
        icon="mail"
        placeholder="Email Address"
        required
        autocomplete="email"
      />

      <AuthField
        id="password"
        label="Password"
        type="password"
        icon="lock"
        placeholder="Password"
        required
        minlength={8}
        autocomplete="new-password"
        class="auth-field--full"
      />

      <AuthField
        id="confirm-password"
        label="Confirm Password"
        type="password"
        icon="lock"
        placeholder="Confirm Password"
        required
        minlength={8}
        autocomplete="new-password"
        class="auth-field--full"
      />

      <p class="auth-link auth-field--full">
        Already have an account? <a href="/login">Login</a>
      </p>

      <div class="auth-field--full">
        <AuthSubmit id="register-btn" label="Register" />
      </div>
    </form>
  </AuthShell>
</AuthLayout>

<script>
  import { register, getPostLoginRedirect, currentUser, waitForAuth } from '../stores/authStore';

  const form = document.getElementById('register-form') as HTMLFormElement;
  const errorEl = document.getElementById('register-error')!;
  const btn = document.getElementById('register-btn') as HTMLButtonElement;
  const btnLabel = btn.querySelector('span')!;

  waitForAuth().then(() => {
    const user = currentUser.get();
    if (user) {
      window.location.replace(getPostLoginRedirect(user));
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.classList.add('hidden');
    btn.disabled = true;
    btnLabel.textContent = 'Creating account...';

    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const password = (document.getElementById('password') as HTMLInputElement).value;
    const confirmPassword = (document.getElementById('confirm-password') as HTMLInputElement).value;

    if (password !== confirmPassword) {
      errorEl.textContent = 'Passwords do not match';
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btnLabel.textContent = 'Register';
      return;
    }

    try {
      const data = await register({ name, email, password });
      window.location.href = getPostLoginRedirect(data.user);
    } catch (err: unknown) {
      const message = err instanceof Error ? err.message : 'Registration failed';
      errorEl.textContent = message;
      errorEl.classList.remove('hidden');
      btn.disabled = false;
      btnLabel.textContent = 'Register';
    }
  });
</script>
