---
import MainLayout from '../layouts/MainLayout.astro';
import Button from '../components/ui/Button.astro';
---

<MainLayout title="Cart - Petmania" description="Review your shopping cart.">
  <div class="bg-light py-8 border-b border-border">
    <div class="container-main">
      <h1 class="text-3xl md:text-4xl font-bold text-heading mb-2">Shopping Cart</h1>
      <nav class="text-sm text-muted">
        <a href="/" class="hover:text-primary">Home</a>
        <span class="mx-2">/</span>
        <span class="text-heading">Cart</span>
      </nav>
    </div>
  </div>

  <section class="py-12 md:py-16">
    <div class="container-main">
      <div id="cart-empty" class="hidden text-center py-16">
        <h2 class="text-2xl font-bold text-heading mb-4">Your cart is empty</h2>
        <p class="text-muted mb-6">Looks like you haven't added any products yet.</p>
        <Button href="/shop" variant="primary" size="lg">Continue Shopping</Button>
      </div>

      <div id="cart-content" class="hidden flex-col lg:flex-row gap-8">
        <!-- Cart Items -->
        <div class="flex-1">
          <div class="bg-white rounded-xl shadow-card overflow-hidden">
            <div class="hidden md:grid grid-cols-12 gap-4 p-4 border-b border-border bg-light text-sm font-semibold text-heading">
              <div class="col-span-6">Product</div>
              <div class="col-span-2 text-center">Price</div>
              <div class="col-span-2 text-center">Quantity</div>
              <div class="col-span-2 text-center">Total</div>
            </div>
            <div id="cart-items" class="divide-y divide-border">
              <!-- Items injected via JS -->
            </div>
          </div>
        </div>

        <!-- Summary -->
        <div class="w-full lg:w-96 shrink-0">
          <div class="bg-white rounded-xl p-6 shadow-card">
            <h3 class="text-xl font-bold text-heading mb-4">Cart Totals</h3>
            <div class="space-y-3 mb-6">
              <div class="flex items-center justify-between text-sm">
                <span class="text-muted">Subtotal</span>
                <span id="cart-subtotal" class="font-semibold text-heading">$0.00</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-muted">Shipping</span>
                <span class="font-semibold text-heading">Free</span>
              </div>
              <div class="border-t border-border pt-3 flex items-center justify-between">
                <span class="text-heading font-semibold">Total</span>
                <span id="cart-total-summary" class="text-xl font-bold text-primary">$0.00</span>
              </div>
            </div>
            <Button href="#" variant="primary" size="lg" class="w-full justify-center">
              Proceed to Checkout
            </Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<script>
  import { cartItems, cartTotal, removeFromCart, updateQuantity } from '../stores/cartStore';

  const emptyEl = document.getElementById('cart-empty');
  const contentEl = document.getElementById('cart-content');
  const itemsEl = document.getElementById('cart-items');
  const subtotalEl = document.getElementById('cart-subtotal');
  const totalEl = document.getElementById('cart-total-summary');

  function renderCart() {
    const items = cartItems.get();

    if (items.length === 0) {
      emptyEl?.classList.remove('hidden');
      contentEl?.classList.add('hidden');
      contentEl?.classList.remove('flex');
      return;
    }

    emptyEl?.classList.add('hidden');
    contentEl?.classList.remove('hidden');
    contentEl?.classList.add('flex');

    if (itemsEl) {
      itemsEl.innerHTML = items
        .map(
          (item) => `
          <div class="p-4 grid grid-cols-1 md:grid-cols-12 gap-4 items-center">
            <div class="col-span-6 flex items-center gap-4">
              <img src="${item.product.image}" alt="${item.product.name}" class="w-20 h-20 object-cover rounded-lg bg-light" />
              <div>
                <a href="/product/${item.product.slug}" class="font-semibold text-heading hover:text-primary transition-colors">${item.product.name}</a>
                <p class="text-xs text-muted mt-1">${item.product.category}</p>
                <button type="button" class="remove-item text-xs text-sale hover:underline mt-2" data-id="${item.product.id}">Remove</button>
              </div>
            </div>
            <div class="col-span-2 text-center">
              <span class="md:hidden text-muted text-sm mr-2">Price:</span>
              <span class="font-semibold text-heading">$${item.product.price.toFixed(2)}</span>
            </div>
            <div class="col-span-2 flex justify-center">
              <div class="flex items-center border border-border rounded-pill overflow-hidden">
                <button type="button" class="qty-minus w-8 h-9 text-heading hover:bg-light transition-colors" data-id="${item.product.id}">-</button>
                <input type="text" value="${item.quantity}" class="w-10 h-9 text-center text-sm text-heading outline-none border-x border-border" readonly />
                <button type="button" class="qty-plus w-8 h-9 text-heading hover:bg-light transition-colors" data-id="${item.product.id}">+</button>
              </div>
            </div>
            <div class="col-span-2 text-center">
              <span class="md:hidden text-muted text-sm mr-2">Total:</span>
              <span class="font-bold text-primary">$${(item.product.price * item.quantity).toFixed(2)}</span>
            </div>
          </div>
        `
        )
        .join('');
    }

    const total = cartTotal.get();
    if (subtotalEl) subtotalEl.textContent = `$${total.toFixed(2)}`;
    if (totalEl) totalEl.textContent = `$${total.toFixed(2)}`;

    // Attach events
    document.querySelectorAll('.remove-item').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        if (id) removeFromCart(id);
      });
    });

    document.querySelectorAll('.qty-minus').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const item = cartItems.get().find((i) => i.product.id === id);
        if (id && item) updateQuantity(id, item.quantity - 1);
      });
    });

    document.querySelectorAll('.qty-plus').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const item = cartItems.get().find((i) => i.product.id === id);
        if (id && item) updateQuantity(id, item.quantity + 1);
      });
    });
  }

  cartItems.subscribe(renderCart);
  renderCart();
</script>
